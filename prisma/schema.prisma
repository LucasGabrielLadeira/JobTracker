generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Job {
  id        String   @id @default(uuid())
  company   String
  role      String
  status    String
  link      String?
  notes     String?
  createdAt DateTime @default(now())
}